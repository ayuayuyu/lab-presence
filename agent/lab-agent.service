[Unit]
Description=Lab Presence Agent (MAC scanner)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
ExecStart=/usr/local/bin/lab-agent --backend http://localhost:80 --interval 1m
Restart=always
RestartSec=10

# arp-scan には root 権限が必要
User=root

[Install]
WantedBy=multi-user.target
